# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # set to "production" in prod

# ── Prixe Stock API ───────────────────────────────────────────────────────────
PRIXE_API_KEY=your_prixe_api_key_here
PRIXE_BASE_URL=https://api.prixe.com  # adjust if different

# ── x402 Payment Settings ─────────────────────────────────────────────────────
# Your wallet private key (for verifying/signing payment proofs — KEEP SECRET)
X402_PRIVATE_KEY=0xabc123...your_private_key_here

# The USDC receiving address on Base Sepolia that clients pay to
X402_PAYMENT_ADDRESS=0xYourBaseSepoliaWalletAddressHere

# Price per request in USDC (you charge $0.002, Prixe costs $0.001 → $0.001 margin)
PRICE_PER_REQUEST_USDC=0.002

# Session window: how many seconds a single payment unlocks (default: 60)
PAYMENT_SESSION_SECONDS=60

# ── Base Sepolia RPC ──────────────────────────────────────────────────────────
# Get a free key from Alchemy (https://alchemy.com) or Infura
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# USDC contract on Base Sepolia (official Circle deployment)
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Minimum confirmations required before accepting a payment
MIN_CONFIRMATIONS=1

# ── Free Tier ─────────────────────────────────────────────────────────────────
FREE_REQUESTS_PER_IP=3

# ── SQLite ────────────────────────────────────────────────────────────────────
DB_PATH=./data/prixe.db

# ── Security ──────────────────────────────────────────────────────────────────
# Random 32-char string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=your_random_32_char_secret_here
